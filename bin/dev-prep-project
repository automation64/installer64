source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-project || exit 1

function my_prepare() {
  bl64_dbg_app_show_function
  bl64_msg_show_task 'Normalize repository permissions'
  bl64_fs_path_permission_set '0755' '0755' "$BL64_VAR_DEFAULT" "$BL64_VAR_DEFAULT" "$BL64_VAR_ON" \
    "$DEV_PATH_BIN" \
    "$DEV_PATH_LIB" \
    "$DEV_PATH_SRC" \
    "$DEV_PATH_TEST"
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize
}

bl64_lib_script_version_set '2.0.0'
bl64_msg_help_set_about 'Run dev-time source code maintenance tasks'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_prepare
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
