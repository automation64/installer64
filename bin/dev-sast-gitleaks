source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-gitleaks || exit 1

declare MY_TARGET="${1:-$DEV_PATH_ROOT}"

function my_sast() {
  bl64_dbg_app_show_function
  "$DEV_LIB_GITLEAKS_BIN" \
    detect \
    --redact \
    --verbose \
    --exit-code 1 \
    --report-format "$DEV_SAST_GITLEAKS_FORMAT" \
    --report-path "$DEV_SAST_GITLEAKS_PATH_REPORT" \
    "$MY_TARGET"
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_log_setup "$BL64_VAR_ON" "$DEV_ENV_GITLEAKS_PATH_LOGS" &&
    bl64_check_command "$DEV_LIB_GITLEAKS_BIN" &&
    dev_base_task_show_setup \
      'DEV_SAST_GITLEAKS_PATH_REPORT' \
      'MY_TARGET'
}

bl64_lib_script_version_set '1.2.0'
bl64_msg_help_set_about 'Static test source code security'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_sast
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
