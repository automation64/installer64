source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-shellcheck || exit 1

declare MY_TARGET="${*:-$DEV_LINT_SHELLCHECK_TARGET}"

function my_lint_local() {
  bl64_dbg_app_show_function "$@"
  local target="$1"
  dev_shellcheck_run_shellcheck \
    --wiki-link-count=0 \
    --severity=info \
    --format="$DEV_LINT_SHELLCHECK_FORMAT" \
    "$target" >>"$DEV_LINT_SHELLCHECK_PATH_REPORT"
}

function my_lint() {
  bl64_dbg_app_show_function
  local current=''

  if [[ -d "$MY_TARGET" ]]; then
    MY_TARGET="$(bl64_fs_file_search "$MY_TARGET")" ||
      return $?
  fi

  echo '' >"$DEV_LINT_SHELLCHECK_PATH_REPORT"
  for current in $MY_TARGET; do
    bl64_msg_show_phase "lint Shell target (${current})"
    my_lint_local "$current"
  done
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_log_setup "$BL64_VAR_ON" "$DEV_ENV_SHELLCHECK_PATH_LOGS" &&
    dev_base_lib_check_command "$DEV_ENV_SHELLCHECK_ID" "$DEV_LIB_SHELLCHECK_BIN" &&
    dev_base_task_show_setup \
      'DEV_LINT_SHELLCHECK_PATH_REPORT' \
      'MY_TARGET'
}

bl64_lib_script_version_set '2.2.0'
bl64_msg_help_set_about 'Lint source code'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_lint
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
