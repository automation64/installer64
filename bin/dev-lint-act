source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-act || exit 1

function my_lint() {
  bl64_dbg_app_show_function
  dev_act_run_act \
    --verbose \
    --validate \
    --strict \
    --use-gitignore >"$DEV_LINT_ACT_PATH_REPORT" 2>&1
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_log_setup "$BL64_VAR_OFF" "$DEV_ENV_ACT_PATH_LOGS" &&
    dev_base_lib_check_command "$DEV_ENV_ACT_ID" "$DEV_LIB_ACT_BIN" &&
    dev_base_task_show_setup \
      'DEV_LINT_ACT_PATH_REPORT'
}

bl64_lib_script_version_set '1.1.0'
bl64_msg_help_set_about 'Lint GitHub workflows'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_lint
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
