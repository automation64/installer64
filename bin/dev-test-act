source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-act || exit 1

declare MY_WORKFLOWS="${1:-${DEV_TEST_ACT_WORKFLOWS}}"

function my_test() {
  bl64_dbg_app_show_function
  local job=''
  local docker_group_id=''

  docker_group_id="$(stat -c '%g' "$DEV_LIB_ACT_DOCKER_SOCKET")" &&
    [[ -n "$docker_group_id" ]] ||
    return $?

  for job in $MY_WORKFLOWS; do
    bl64_msg_show_phase "run GitHub Actions workflow (${job})"
    dev_act_run_act \
      --strict \
      --use-gitignore \
      --container-options "--group-add ${docker_group_id}" \
      --concurrent-jobs="$DEV_TEST_ACT_JOBS_MAX" \
      --artifact-server-port="$DEV_LIB_ACT_PORT_ARTIFACT" \
      --artifact-server-path="$DEV_LIB_ACT_PATH_ARTIFACT" \
      --action-cache-path="$DEV_LIB_ACT_PATH_CACHE_ACTION" \
      --cache-server-path="$DEV_LIB_ACT_PATH_CACHE_SERVER" \
      --job=${job} >"${DEV_ENV_ACT_PATH_LOGS}/${DEV_TEST_ACT_PREFIX_REPORT}${job}.${DEV_TEST_ACT_FORMAT}" 2>&1 ||
      return $?
  done
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_log_setup "$BL64_VAR_OFF" "$DEV_ENV_ACT_PATH_LOGS" &&
    dev_base_lib_check_command "$DEV_ENV_ACT_ID" "$DEV_LIB_ACT_BIN" &&
    bl64_check_parameter 'MY_WORKFLOWS' &&
    bl64_check_export 'DEV_ENV_ACT_PATH_LOGS' &&
    dev_base_task_show_setup \
      'MY_WORKFLOWS' \
      'DEV_ENV_ACT_PATH_LOGS'
}

bl64_lib_script_version_set '1.6.0'
bl64_msg_help_set_about 'Test GitHub Actions workflows'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_test
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
