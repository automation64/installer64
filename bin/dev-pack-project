source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-project || exit 1

function my_prepare() {
  bl64_dbg_app_show_function
  bl64_msg_show_task 'gather distributable package content'
  # shellcheck disable=SC2086
  bl64_fs_path_copy \
    '0755' \
    "$BL64_VAR_DEFAULT" \
    "$BL64_VAR_DEFAULT" \
    "$BL64_VAR_DEFAULT" \
    "$DEV_PACK_PROJECT_PATH_STAGING" \
    "${DEV_PATH_SRC}"/install-* \
    "${DEV_PATH_SRC}"/lib-* &&
    bl64_fs_path_copy \
      '0755' \
      "$BL64_VAR_DEFAULT" \
      "$BL64_VAR_DEFAULT" \
      "$BL64_VAR_DEFAULT" \
      "$DEV_PACK_PROJECT_PATH_TARGET" \
      "${DEV_PATH_SRC}/${DEV_ENV_PROJECT_BOOTSTRAP_FILE}" \
      "${DEV_PACK_PROJECT_PATH_STAGING}/${DEV_ENV_PROJECT_INSTALLER_FILE}" ||
    return $?
}

function my_create() {
  bl64_dbg_app_show_function
  bl64_msg_show_task 'create distributable bundle'
  # shellcheck disable=SC2086,SC2035
  cd "$DEV_PACK_PROJECT_PATH_STAGING" &&
    bl64_arc_run_tar \
      czf "${DEV_PACK_PROJECT_PATH_TARGET}/${DEV_PACK_PROJECT_BUNDLE}" \
      $BL64_ARC_SET_TAR_VERBOSE \
      *
}

function my_pack() {
  bl64_dbg_app_show_function
  my_prepare &&
    my_create
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    bl64_arc_setup &&
    dev_base_pack_setup "$DEV_PACK_PROJECT_PATH_TARGET" "$DEV_PACK_PROJECT_PATH_STAGING" &&
    dev_base_task_show_setup \
      'DEV_BUILD_PROJECT_PATH_OUTPUT' \
      'DEV_PACK_PROJECT_PATH_TARGET' \
      'DEV_PACK_PROJECT_BUNDLE'
}

bl64_lib_script_version_set '3.0.0'
bl64_msg_help_about_set 'Pack application for release'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_pack
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
