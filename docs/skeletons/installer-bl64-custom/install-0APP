  # optional #   if [[ -z "$INST64_X_APP_NAME_CAPS_X_PLATFORM" ]]; then
  # optional #     INST64_X_APP_NAME_CAPS_X_PLATFORM="$INST64_CPU_ALL_ALL"
  # optional #   fi
  # optional #   inst64_lib_base_check_platform
  # optional # fi
  # optional # return 0
}

function my_select_packages() {
  bl64_dbg_app_show_function
  inst64_lib_show_task_select_packages
