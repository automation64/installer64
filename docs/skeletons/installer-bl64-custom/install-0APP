  # optional # inst64_lib_base_check_package
}

function my_initialize() {
  bl64_dbg_app_show_function
  my_select_method &&
    inst64_lib_base_setup ||
    return $?

  # X_INIT_PLACEHOLDER_X
  # optional # if [[ "$INST64_X_APP_NAME_CAPS_X_METHOD" == "$INST64_METHOD_CUSTOM" ]]; then
  # optional #   inst64_lib_base_check_prereq_exe 'X_COMMAND_NAME_X'
  # optional # fi

  my_select_platform &&
    my_select_packages ||
    return $?

  # X_INIT_PLACEHOLDER_X
  # optional # if [[ "$INST64_X_APP_NAME_CAPS_X_METHOD" == "$INST64_METHOD_CUSTOM" ]]; then
  # optional #   INST64_CLI_PATH='X_PATH_DIR_X'
  # optional #   INST64_CLI_SOURCE="X_CUSTOM_CLI_NAME"
  # optional #   INST64_CLI_SUBPATH='X_CUSTOM_CLI_SUBPATH_X'
  # optional #   INST64_CLI_TARGET='X_PATH_FILE_X'
  # optional #   INST64_WEB_REPO_PATH="X_CUSTOM_URL_X"
  # optional #   INST64_WORK_PATH_SOURCE="X_CUSTOM_FILE_NAME_X"
  # optional # fi

  inst64_lib_base_finalize
}

#
# Main
#

bl64_lib_script_version_set '1.0.0'
inst64_lib_base_initialize
bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_initialize &&
  my_prepare &&
  my_install &&
  my_setup &&
  my_verify
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
