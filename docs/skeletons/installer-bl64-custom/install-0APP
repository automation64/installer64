  # optional #   inst64_lib_setup_promote
  # optional # fi
}

function my_verify() {
  bl64_dbg_app_show_function
  inst64_lib_show_step_verify || return 0
  # X_VERIFY_PLACEHOLDER_X
  # example # "${INST64_CLI_TARGET}" --version
}

function my_select_method() {
  bl64_dbg_app_show_function
  inst64_lib_method_check \
    "$INST64_METHOD_AUTO" \
    "$INST64_METHOD_CUSTOM" ||
    return $?
  if [[ "$INST64_X_APP_NAME_CAPS_X_METHOD" == "$INST64_METHOD_AUTO" ]]; then
    INST64_X_APP_NAME_CAPS_X_METHOD="$INST64_METHOD_CUSTOM"
  fi
  # optional # if [[ "$INST64_X_APP_NAME_CAPS_X_METHOD" == "$INST64_METHOD_CUSTOM" ]]; then
  # optional #   INST64_SYSTEM_WIDE='NO'
  # optional # fi
}

